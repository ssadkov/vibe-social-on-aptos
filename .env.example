# Default network: devnet | testnet | mainnet
# Note: the UI has a network switcher (saved in localStorage) that can override this.
VITE_APP_NETWORK=devnet

# Publisher account (for compile + publish scripts only).
# IMPORTANT: never set these in Vercel (frontend does NOT need them).
# IMPORTANT: Address must be the account that owns the private key (same as key's address).
VITE_MODULE_PUBLISHER_ACCOUNT_ADDRESS=
VITE_MODULE_PUBLISHER_ACCOUNT_PRIVATE_KEY=

# Deployed module addresses (object) per network (recommended).
# You can still use VITE_MODULE_ADDRESS as a fallback for a single-network setup.
VITE_MODULE_ADDRESS_DEVNET=
VITE_MODULE_ADDRESS_TESTNET=
VITE_MODULE_ADDRESS_MAINNET=

# Backward-compatible single module address (fallback)
VITE_MODULE_ADDRESS=

# Optional: Aptos API key (for higher rate limits)
# VITE_APTOS_API_KEY=
